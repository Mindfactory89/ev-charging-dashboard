# Docker / database
POSTGRES_DB=mobility
POSTGRES_USER=mobility
POSTGRES_PASSWORD=change_me_local_password

# Advanced / private network
# Only needed for docker-compose.yml with explicit Tailscale binding.
TAILSCALE_IP=100.64.0.10
API_PORT=18800
UI_PORT=18801
UI_PORT_LOCAL=18801

# Optional: feste API-URL für UI-Build.
# Leer lassen, wenn die UI dynamisch hostname:18800 verwenden soll.
VITE_API_BASE=

# Optional: dedizierte API-URL für native Android/iOS-Builds.
# Wenn gesetzt, überschreibt sie im Mobile-Container die automatische Host-Erkennung.
VITE_MOBILE_API_BASE=

# Optional: aktives Hero-/Fahrzeugprofil im UI-Build.
# Verfuegbare IDs aktuell: cupra-born, cupra-tavascan, cupra-raval, generic-ev
# cupra-born = mitgeliefertes CUPRA-Born-Layout
# cupra-tavascan / cupra-raval = Modellprofile mit eigenen Hero-Bildern und Specs
# generic-ev = neutrales EV-Layout
VITE_VEHICLE_PROFILE=cupra-born

# Optional: Demo-Hosts über Präfix aktivieren, z. B. demo.
VITE_DEMO_HOST_PREFIX=

# Optional: privater Telegram-Bot für Session-Erfassung
# BotFather-Token des Bots
TELEGRAM_BOT_TOKEN=
# Erlaubte private Chat-IDs, komma-separiert, z. B. 123456789,987654321
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional: Deploy-Script Defaults
SSH_DEPLOY_HOST=your.server.ip
SSH_DEPLOY_USER=your-ssh-user
SSH_DEPLOY_PATH=/srv/mobility-dashboard
